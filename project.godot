; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Ui React"
run/main_scene="res://addons/ui_react/examples/inventory_screen_demo.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[editor_plugins]

enabled=PackedStringArray("res://addons/ui_react/editor_plugin/plugin.cfg")

[ui_react]

plugin_state_output_path="res://addons/ui_react/ui_resources/plugin_generated/"
plugin_scan_mode=1
plugin_show_errors=true
plugin_show_warnings=true
plugin_show_info=true
plugin_auto_refresh=true
plugin_group_mode=1
plugin_ignored_unused_state_paths=PackedStringArray()
plugin_graph_scope_presets_json="[]"
plugin_graph_active_scope_preset_name=""
plugin_graph_body_vsplit_offset=160
plugin_graph_legend_visible=true
plugin_graph_body_hsplit_offset=-1
