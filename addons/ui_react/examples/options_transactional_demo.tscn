[sub_resource type="Resource" id="txn_vol"]
script = ExtResource("2_txn")
committed_value = 0.65

[sub_resource type="Resource" id="txn_mute"]
script = ExtResource("2_txn")
committed_value = false

[sub_resource type="Resource" id="txn_group"]
