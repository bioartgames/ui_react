[node name="OptionsTransactionalDemo" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_root")
master_volume_state = SubResource("txn_vol")
mute_state = SubResource("txn_mute")
transactional_group = SubResource("txn_group")
status_text_state = SubResource("status_str")

[node name="TxnActions" type="Control" parent="."]
anchors_preset = 0
mouse_filter = 2
script = ExtResource("6_act")
group = SubResource("txn_group")
apply_button_path = NodePath("../VBox/ButtonRow/ApplyButton")
cancel_button_path = NodePath("../VBox/ButtonRow/CancelButton")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 24.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = -24.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Options (transactional demo — audio)"

[node name="Help" type="Label" parent="VBox"]
layout_mode = 2
text = "Adjust volume and mute, then Apply (commit) or Cancel (revert draft)."

[node name="VolumeLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Master volume (linear 0–1)"

[node name="MasterVolume" type="HSlider" parent="VBox"]
layout_mode = 2
size_flags_horizontal = 3
max_value = 1.0
step = 0.01
value = 0.65
script = ExtResource("3_sl")
