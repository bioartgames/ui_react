[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Options (transactional demo — audio)"

[node name="Help" type="Label" parent="VBox"]
custom_minimum_size = Vector2(1, 1)
layout_mode = 2
text = "Audio settings are on the first tab. Second tab is a static UiReactTabContainer showcase. Apply / Cancel use UiReactButton transactional_role + UiTransactionalScreenConfig (UiReactTransactionalSession). CB-052: TabContainer + OptionButton use wire_rules (copy-detail + map) and action_targets (SET_VISIBLE). CB-056: CheckBox state_watch SET_VISIBLE (visible_when_true / visible_when_false)."
autowrap_mode = 3

