[ext_resource type="Script" uid="uid://3a3144h5usfc" path="res://addons/ui_react/scripts/api/models/ui_string_state.gd" id="6_str"]
[ext_resource type="Script" uid="uid://dwwa3tekslkjw" path="res://addons/ui_react/scripts/api/models/ui_array_state.gd" id="7_arr"]
[ext_resource type="Script" uid="uid://dxvrutpo1gjxg" path="res://addons/ui_react/scripts/api/models/ui_int_state.gd" id="8_int"]
[ext_resource type="Script" uid="uid://cxg5hj6ihqtue" path="res://addons/ui_react/scripts/api/models/ui_bool_state.gd" id="9_bool"]

[sub_resource type="Resource" id="filter_str"]
script = ExtResource("6_str")

[sub_resource type="Resource" id="items_arr"]
script = ExtResource("7_arr")

[sub_resource type="Resource" id="sel_int"]
script = ExtResource("8_int")
value = -1

[sub_resource type="Resource" id="detail_str"]
script = ExtResource("6_str")
value = "No selection."

[sub_resource type="Resource" id="locked_bool"]
script = ExtResource("9_bool")

[node name="InventoryListDemo" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_inv")
filter_text_state = SubResource("filter_str")
items_state = SubResource("items_arr")
selected_state = SubResource("sel_int")
detail_text_state = SubResource("detail_str")
list_locked_state = SubResource("locked_bool")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 24.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = -24.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Inventory list (P3 demo — filter + ItemList)"

[node name="Help" type="Label" parent="VBox"]
layout_mode = 2
text = "Type in the filter to narrow rows (name or kind). Selection is the filtered index. Lock blocks clicks on the list (parent overlay + mouse_filter)."

[node name="FilterLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Filter"

[node name="FilterEdit" type="LineEdit" parent="VBox"]
layout_mode = 2
placeholder_text = "e.g. weapon, wood, potion…"
script = ExtResource("2_le")
text_state = SubResource("filter_str")

[node name="LockRow" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="LockList" type="CheckBox" parent="VBox/LockRow"]
layout_mode = 2
text = "Lock list (blocks pointer input — CB-015)"
script = ExtResource("5_cb")
checked_state = SubResource("locked_bool")

[node name="ListLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Items"

[node name="ListSlot" type="Control" parent="VBox"]
custom_minimum_size = Vector2(0, 220)
layout_mode = 2
size_flags_vertical = 3

[node name="ItemList" type="ItemList" parent="VBox/ListSlot"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("3_il")
selected_state = SubResource("sel_int")
items_state = SubResource("items_arr")

[node name="InputBlocker" type="Control" parent="VBox/ListSlot"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="DetailLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Detail"

[node name="Detail" type="Label" parent="VBox"]
custom_minimum_size = Vector2(1, 1)
layout_mode = 2
autowrap_mode = 2
script = ExtResource("4_lbl")
text_state = SubResource("detail_str")
