float_factor_b = SubResource("qty")

[node name="ShopComputedDemo" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 24.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = -24.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Shop (computed state demo)"

[node name="Help" type="Label" parent="VBox"]
custom_minimum_size = Vector2(1, 1)
layout_mode = 2
text = "Adjust gold, price, and quantity. Gold meter + quantity spin box are showcase bindings (shared gold/qty state). Status line is UiReactRichTextLabel + BBCode from UiComputedOrderSummaryThreeFloatString; afford/disabled use UiComputedFloatGeProductBool + UiComputedBoolInvert. Buy subtracts gold via action_targets SUBTRACT_PRODUCT_FROM_FLOAT (UiReactStateOpService)."
autowrap_mode = 3

[node name="ScrollShop" type="ScrollContainer" parent="VBox"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="ShopInner" type="VBoxContainer" parent="VBox/ScrollShop"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 12

[node name="GoldLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
text = "Player gold"

[node name="GoldSlider" type="HSlider" parent="VBox/ScrollShop/ShopInner"]
