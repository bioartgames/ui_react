[sub_resource type="Resource" id="gold"]
script = ExtResource("1_fl")
value = 100.0

[sub_resource type="Resource" id="price"]
script = ExtResource("1_fl")
value = 25.0

[sub_resource type="Resource" id="qty"]
script = ExtResource("1_fl")
value = 1.0

[sub_resource type="Resource" id="afford"]
script = ExtResource("7_aff")
sources = Array[ExtResource("2_st")]([SubResource("gold"), SubResource("price"), SubResource("qty")])
value = true

[sub_resource type="Resource" id="buy_dis"]
script = ExtResource("8_dis")
sources = Array[ExtResource("2_st")]([SubResource("afford")])

[sub_resource type="Resource" id="status"]
script = ExtResource("9_stat")
sources = Array[ExtResource("2_st")]([SubResource("gold"), SubResource("price"), SubResource("qty")])
value = "Total: 25.00 | Gold: 100.00 | Can afford"

[node name="ShopComputedDemo" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="SyncAfford" type="Control" parent="."]
