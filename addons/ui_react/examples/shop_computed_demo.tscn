max_value = 10.0
value = 1.0
script = ExtResource("3_sl")
value_state = SubResource("qty")

[node name="QtySpinLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
text = "Quantity (UiReactSpinBox — same state as slider; disabled when Buy disabled)"

[node name="QtySpin" type="SpinBox" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
min_value = 0.0
max_value = 10.0
step = 1.0
value = 1.0
script = ExtResource("12_sp")
value_state = SubResource("qty")
disabled_state = SubResource("buy_dis")

[node name="StatusLine" type="RichTextLabel" parent="VBox/ScrollShop/ShopInner"]
custom_minimum_size = Vector2(1, 1)
layout_mode = 2
bbcode_enabled = true
text = "[font_size=18][b]Order summary[/b][/font_size]
[i]Live totals[/i] — Total: [code]25.00[/code]  ·  Gold: [code]100.00[/code]
[color=green][b]Can afford[/b][/color]"
fit_content = true
scroll_active = false
autowrap_mode = 2
script = ExtResource("4_rich")
text_state = SubResource("status")
animation_targets = Array[ExtResource("10_anim")]([SubResource("status_pulse")])

[node name="BuyButton" type="Button" parent="VBox"]
layout_mode = 2
text = "Buy"
script = ExtResource("5_btn")
