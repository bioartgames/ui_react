grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Shop (computed state demo)"

[node name="Help" type="Label" parent="VBox"]
layout_mode = 2
text = "Adjust gold, price, and quantity. Status and Buy disabled state update via UiReactComputedSync (no scene script)."

[node name="GoldLabel" type="Label" parent="VBox"]
layout_mode = 2
