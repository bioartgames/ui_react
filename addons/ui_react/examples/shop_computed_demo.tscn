[node name="PriceLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Item price (each)"

[node name="PriceSlider" type="HSlider" parent="VBox"]
layout_mode = 2
size_flags_horizontal = 3
step = 0.5
value = 25.0
script = ExtResource("3_sl")
value_state = SubResource("price")

[node name="QtyLabel" type="Label" parent="VBox"]
layout_mode = 2
