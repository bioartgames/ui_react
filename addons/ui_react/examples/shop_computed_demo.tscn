[sub_resource type="Resource" id="gold"]
script = ExtResource("1_fl")
value = 100.0

[sub_resource type="Resource" id="price"]
script = ExtResource("1_fl")
value = 25.0

[sub_resource type="Resource" id="qty"]
script = ExtResource("1_fl")
value = 1.0

[sub_resource type="Resource" id="afford"]
script = ExtResource("7_aff")
sources = Array[ExtResource("2_st")]([SubResource("gold"), SubResource("price"), SubResource("qty")])
value = true

[sub_resource type="Resource" id="buy_dis"]
script = ExtResource("8_dis")
sources = Array[ExtResource("2_st")]([SubResource("afford")])

[sub_resource type="Resource" id="status"]
script = ExtResource("9_stat")
sources = Array[ExtResource("2_st")]([SubResource("gold"), SubResource("price"), SubResource("qty")])
value = "[font_size=18][b]Order summary[/b][/font_size]
[i]Live totals[/i] — Total: [code]25.00[/code]  ·  Gold: [code]100.00[/code]
[color=green][b]Can afford[/b][/color]"

[sub_resource type="Resource" id="status_pulse"]
script = ExtResource("10_anim")
target = NodePath(".")
trigger = 5
animation = 17
duration = 0.22
pulse_amount = 1.06
pulse_count = 1

[node name="ShopComputedDemo" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("0_shop")
gold_state = SubResource("gold")
price_state = SubResource("price")
quantity_state = SubResource("qty")

[node name="SyncAfford" type="Control" parent="."]
anchors_preset = 0
mouse_filter = 2
script = ExtResource("6_sync")
computed = SubResource("afford")

[node name="SyncBuyDisabled" type="Control" parent="."]
anchors_preset = 0
mouse_filter = 2
script = ExtResource("6_sync")
computed = SubResource("buy_dis")

[node name="SyncStatus" type="Control" parent="."]
anchors_preset = 0
mouse_filter = 2
script = ExtResource("6_sync")
computed = SubResource("status")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 24.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = -24.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Shop (computed state demo)"

[node name="Help" type="Label" parent="VBox"]
custom_minimum_size = Vector2(1, 1)
layout_mode = 2
text = "Adjust gold, price, and quantity. Status line is UiReactRichTextLabel + BBCode from ShopComputedStatus; Buy subtracts gold via shop_computed_demo.gd (CB-006)."
autowrap_mode = 3

[node name="GoldLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "Player gold"

[node name="GoldSlider" type="HSlider" parent="VBox"]
layout_mode = 2
size_flags_horizontal = 3
max_value = 200.0
value = 100.0
script = ExtResource("3_sl")
