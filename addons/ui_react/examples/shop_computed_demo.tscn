[i]Live totals[/i] — Total: [code]25.00[/code]  ·  Gold: [code]100.00[/code]
[color=green][b]Can afford[/b][/color]"

[sub_resource type="Resource" id="status_pulse"]
script = ExtResource("10_anim")
target = NodePath(".")
trigger = 5
animation = 17
duration = 0.22
