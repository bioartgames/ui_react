[node name="ShopComputedDemo" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 24.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = -24.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Shop (computed state demo)"

[node name="Help" type="Label" parent="VBox"]
custom_minimum_size = Vector2(1, 1)
layout_mode = 2
text = "Adjust gold, price, and quantity. Gold meter + quantity spin box are showcase bindings (shared gold/qty state). Status line is UiReactRichTextLabel + BBCode from UiComputedOrderSummaryThreeFloatString; afford/disabled use UiComputedFloatGeProductBool + UiComputedBoolInvert. Action layer (UiReactStateOpService): Buy = SUBTRACT_PRODUCT_FROM_FLOAT; Sell = ADD_PRODUCT_TO_FLOAT (refund price×qty); Deposit = TRANSFER_FLOAT_PRODUCT_CLAMPED (gold→bank, clamped by price×qty); Add tickets = ADD_PRODUCT_TO_INT (tickets += 2×3); Tip = TRANSFER_INT_PRODUCT_CLAMPED (tickets→gift, clamped by 2×3)."
autowrap_mode = 3

[node name="ScrollShop" type="ScrollContainer" parent="VBox"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="ShopInner" type="VBoxContainer" parent="VBox/ScrollShop"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 12

[node name="GoldLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
text = "Player gold"

[node name="GoldSlider" type="HSlider" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
size_flags_horizontal = 3
max_value = 200.0
value = 100.0
script = ExtResource("3_sl")
value_state = SubResource("gold")

[node name="GoldMeterLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
text = "Gold meter (UiReactProgressBar — same UiFloatState as slider)"

[node name="GoldMeter" type="ProgressBar" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
max_value = 200.0
value = 100.0
show_percentage = false
script = ExtResource("11_pb")
value_state = SubResource("gold")

[node name="BankLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
text = "Bank pool (UiFloatState — TRANSFER_FLOAT_PRODUCT_CLAMPED destination)"

[node name="BankMeter" type="ProgressBar" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
max_value = 200.0
value = 0.0
show_percentage = false
script = ExtResource("11_pb")
value_state = SubResource("bank")

[node name="TicketsLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
text = "Tickets (UiIntState — ADD_PRODUCT_TO_INT / TRANSFER_INT_PRODUCT_CLAMPED)"

[node name="TicketsMeter" type="ProgressBar" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
max_value = 100.0
value = 10.0
show_percentage = false
script = ExtResource("11_pb")
value_state = SubResource("tickets")

[node name="GiftLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
text = "Gift jar (UiIntState — tip destination)"

[node name="GiftMeter" type="ProgressBar" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
max_value = 100.0
value = 0.0
show_percentage = false
script = ExtResource("11_pb")
value_state = SubResource("gift")

[node name="PriceLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
text = "Item price (each)"

[node name="PriceSlider" type="HSlider" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
size_flags_horizontal = 3
step = 0.5
value = 25.0
script = ExtResource("3_sl")
value_state = SubResource("price")

[node name="QtyLabel" type="Label" parent="VBox/ScrollShop/ShopInner"]
layout_mode = 2
